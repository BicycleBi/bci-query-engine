# ── Postgres (metadata DB — app config, security, logs) ──────────────
METADATA_DB_HOST=postgres
METADATA_DB_PORT=62345
METADATA_DB_NAME=metadata
METADATA_DB_USER=postgres
METADATA_DB_PASSWORD=
METADATA_DB_SSLMODE=disable

# ── Postgres (data DB — client source data and report views) ─────────
DATA_DB_HOST=postgres
DATA_DB_PORT=62345
DATA_DB_NAME=data
DATA_DB_USER=postgres
DATA_DB_PASSWORD=
DATA_DB_SSLMODE=disable

# ── Email service ─────────────────────────────────────────────────────
EMAIL_SERVICE_URL=http://email-service:8200
EMAIL_SERVICE_TIMEOUT_SECONDS=90
SERVICE_TOKEN=

# Redis cache (disabled by default)
REDIS_ENABLED=false
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_PASSWORD_FILE=
REDIS_SSL=false
REDIS_SSL_CA_CERTS=
REDIS_CONNECT_TIMEOUT_SECONDS=2
REDIS_SOCKET_TIMEOUT_SECONDS=2
CACHE_TTL_SECONDS=3600
CACHE_RENDERED=true

# ── Server ────────────────────────────────────────────────────────────
PORT=8300
